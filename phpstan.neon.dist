parameters:
    level: 5
    paths:
        - src
        - config
        - database
    tmpDir: build/phpstan
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        -
            identifier: larastan.noEnvCallsOutsideOfConfig
            path: config/demo-mode.php
        # Public-API traits consumed by host applications, not used inside src/.
        -
            identifier: trait.unused
            paths:
                - src/Concerns/PreventsDemoWrites.php
                - src/Concerns/BelongsToDemoSandbox.php
        # Soft dependency: the verifier's LicenseManager exists only when the
        # optional laranail/license-verifier package is installed.
        -
            identifier: function.impossibleType
            path: src/Providers/DemoModeServiceProvider.php
